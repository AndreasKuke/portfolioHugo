      <description>&lt;section  id=&#34;عني&#34; class=&#34;section rad-animation-group pb-0&#34;&gt;&#xA;  &lt;div class=&#34;rad-fade-down&#34;&gt;&#xA;    &lt;div class=&#34;row d-flex flex-column-reverse flex-md-row&#34;&gt;&#xA;      &lt;div class=&#34;about__profile-picture col-12 col-md-6&#34;&gt;&#xA;        &#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;        &#xA;        &#xA;&#xA;&#xA;&#xA;    &#xA;    &#xA;&#xA;&#xA;    &lt;picture class=&#34;&#34;&gt;&#xA;            &#xA;            &#xA;&#xA;            &lt;source srcset=&#34;http://localhost:1313/portfolioHugo/images/about/user-picture_hu_973fc830fa40599f.webp 1x, http://localhost:1313/portfolioHugo/images/about/user-picture_hu_8571c72372444988.webp 2x&#34; type=&#34;image/webp&#34; /&gt;&#xA;            &lt;source srcset=&#34;http://localhost:1313/portfolioHugo/images/about/user-picture_hu_1148b2f82969c998.png 1x, http://localhost:1313/portfolioHugo/images/about/user-picture_hu_bcd94ba3964f7f12.png 2x&#34; type=&#34;image/png&#34;&gt;&#xA;&#xA;        &lt;img&#xA;                width=&#34;561&#34;&#xA;                height=&#34;535&#34;&#xA;                class=&#34;lozad img-responsive image-left-overflow&#34;&#xA;                data-src=&#34;http://localhost:1313/portfolioHugo/images/about/user-picture_hu_1148b2f82969c998.png&#34;&#xA;                alt=&#39;&#39;&#xA;                src=&#34;data:image/gif;base64,R0lGODlhBwACAIAAAP///wAAACH5BAEAAAEALAAAAAAHAAIAAAIDjI9YADs=&#34;&#xA;                loading=&#34;lazy&#34;&#xA;                decoding=&#34;async&#34;&#xA;        /&gt;&#xA;    &lt;/picture&gt;&#xA;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;col-12 col-md-6 my-auto&#34;&gt;&#xA;        &lt;h2&gt;عني&lt;/h2&gt;&#xA;        &lt;div class=&#34;about-me content&#34;&gt;&#xA;          باستخدام &lt;code&gt;صيغة HTML&lt;/code&gt;&#xA;        &lt;/div&gt;&#xA;        &#xA;          &lt;a href=&#34;https://www.google.com&#34; target=&#34;_blank&#34; class=&#34;btn btn-primary mt-3&#34;&gt;&#xA;            &lt;i class=&#34;info&#34;&gt;&lt;/i&gt;&#xA;            يمكنك تعديل هذا&#xA;          &lt;/a&gt;&#xA;        &#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/section&gt;&#xA;&#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;&lt;div class=&#34;container&#34; id=&#34;روابط&#34;&gt;&#xA;  &lt;div class=&#34;row platform-links shortcode&#34;&gt;&#xA;    &lt;div class=&#34;col-12&#34;&gt;&#xD;&#xA;    &#xA;     &#xA;    &lt;a&#xA;      href=&#34;https://www.linkedin.com/in/adrianmoreno/&#34;&#xA;      target=&#34;_blank&#34;&#xA;      rel=&#34;noopener noreferrer&#34;&#xA;      aria-label=&#34;linkedin&#34;&#xA;      &gt;&lt;i class=&#34;icon-linkedin&#34;&gt;&lt;/i&gt;&#xA;    &lt;/a&gt;&#xA;&#xD;&#xA;    &#xA;     &#xA;    &lt;a&#xA;      href=&#34;https://github.com/zetxek&#34;&#xA;      target=&#34;_blank&#34;&#xA;      rel=&#34;noopener noreferrer&#34;&#xA;      aria-label=&#34;square-github&#34;&#xA;      &gt;&lt;i class=&#34;icon-square-github&#34;&gt;&lt;/i&gt;&#xA;    &lt;/a&gt;&#xA;&#xD;&#xA;&lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;&#xA;&lt;section&#xA;  id=&#34;التعليم&#34;&#xA;  class=&#34;section section--border-bottom rad-animation-group&#34;&#xA;&gt;&#xA;  &lt;div class=&#34;container-education&#34;&gt;&#xA;    &lt;div class=&#34;row rad-fade-down&#34;&gt;&#xA;      &lt;div class=&#34;col-12&#34;&gt;&#xA;        &lt;h2&gt;التعليم الرسمي&lt;/h2&gt;&#xA;        &lt;div class=&#34;row pt-2 pt-md-4&#34;&gt;&#xA;          &#xA;        &lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/section&gt;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;  &#xA;    &#xA;  &#xA;  &#xA;  &#xA;&#xA;&#xA;&lt;section  id=&#34;الخبرة&#34; class=&#34;section-experience section section--border-bottom rad-animation-group flex-grow-1&#34;&gt;&#xA;  &lt;div class=&#34;row flex-column-reverse flex-md-row rad-fade-down&#34;&gt;&#xA;    &lt;div class=&#34;experience-lis